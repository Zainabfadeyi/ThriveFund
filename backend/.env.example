NODE_ENV=development
PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=thrivefund

JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-to-another-secret-at-least-32-chacters
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@thrivefund.ng
BREVO_SENDER_NAME=ThriveFund

PAYMENT_PROVIDER=nomba

# Log API requests + response previews in terminal (default: on in development)
LOG_HTTP=true
# basic | detailed | debug
LOG_HTTP_LEVEL=detailed

# Signature key configured in the Nomba dashboard for this webhook URL
NOMBA_WEBHOOK_SECRET=

# Nomba live/test credentials.
# Use sandbox with TEST credentials and production with LIVE credentials.
# Sandbox base URL: https://sandbox.nomba.com
# Production base URL: https://api.nomba.com
NOMBA_ENVIRONMENT=sandbox
# NOMBA_BASE_URL=https://sandbox.nomba.com
# NOMBA_CLIENT_ID=
# NOMBA_PRIVATE_KEY=
# NOMBA_PARENT_ACCOUNT_ID=
# NOMBA_SUB_ACCOUNT_ID=
# parent (POST /v1/accounts/virtual) | sub_account (POST /v1/accounts/virtual/{subAccountId})
NOMBA_VIRTUAL_ACCOUNT_SCOPE=sub_account
