NODE_ENV=development
PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=thrivefund

JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-to-another-secret-at-least-32-chacters
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@thrivefund.ng
BREVO_SENDER_NAME=ThriveFund

# mock_nomba (default until July 1) | nomba (live — not implemented yet)
PAYMENT_PROVIDER=mock_nomba

# Optional — used for webhook signature validation in dev
NOMBA_WEBHOOK_SECRET=dev-webhook-secret

# Do NOT set until hackathon build phase — NombaProvider is a placeholder
# NOMBA_BASE_URL=https://api.nomba.com
# NOMBA_API_KEY=
# NOMBA_ACCOUNT_ID=
